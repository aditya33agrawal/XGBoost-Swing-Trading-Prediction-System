# ── Supabase (required for live DB sync; omit to use JSON fallback) ───────────
SUPABASE_URL=https://your-project-ref.supabase.co
# New Supabase API key naming (replaces anon/service_role keys).
# SECRET_KEY is needed for the pipeline (writes); PUBLISHABLE_KEY is enough for
# the read-only Streamlit dashboard. SUPABASE_KEY also still works if you have
# a legacy key.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# ── Optional overrides ────────────────────────────────────────────────────────
# MODEL_VERSION=v20260617          # auto-generated as v{YYYYMMDD} if unset
# LOG_LEVEL=INFO                   # DEBUG / INFO / WARNING
